@page
@model SarasaviLibrary.Pages.Users.ReservationModel
@{
    ViewData["Title"] = "Book Catalog Hub - Sarasavi Library";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Tailwind Custom Animation Configuration Extensions -->
    <style>
        @@keyframes fadeInDown {
        from {
        opacity: 0;
        transform: translateY(-16px);
        }

        to {
        opacity: 1;
        transform: translateY(0);
        }
        }

        @@keyframes fadeInUp {
        from {
        opacity: 0;
        transform: translateY(24px);
        }

        to {
        opacity: 1;
        transform: translateY(0);
        }
        }

        .animate-fade-in-down {
        animation: fadeInDown 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }

        .animate-fade-in-up {
        animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) both;
        }
    </style>
</head>

<body
    class="min-h-screen font-sans antialiased flex flex-col justify-between relative bg-cover bg-center bg-no-repeat bg-fixed m-0 p-0"
    style="background-image: url('/images/reservation.jpg');">

    <!-- Premium Soft Glassmorphism Layer Overlay -->
    <div class="absolute inset-0 bg-slate-900/40 backdrop-blur-[6px] z-0"></div>

    <!-- 🌟 EXACT NAVIGATION HEADER MATRIX (Identical to Home Page, Full-Width, Top Sticky Lock) -->
    <header
        class="w-full bg-white/90 border-b border-white/20 sticky top-0 z-50 shadow-md backdrop-blur-md animate-fade-in-down">
        <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
            <div class="flex items-center space-x-8">
                <a href="/index" class="flex items-center space-x-3 group">
                    <div
                        class="flex items-center justify-center w-10 h-10 rounded-xl bg-gradient-to-br from-blue-600 to-indigo-600 shadow-md transform group-hover:scale-105 transition-transform duration-200">
                        <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2.5"
                             stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M12 21V4.5l7.5-3v16.5L12 21zm0 0L4.5 18V1.5l7.5 3V21z" />
                        </svg>
                    </div>
                    <span
                        class="text-2xl font-bold tracking-tight bg-gradient-to-r from-blue-700 to-indigo-600 bg-clip-text text-transparent group-hover:from-blue-600 group-hover:to-indigo-500 transition-colors">Sarasavi
                        Library</span>
                    </a>

                    <nav class="hidden md:flex items-center space-x-1 border-l border-slate-200 pl-8">
                        <a href="/Users/Home"
                           class="text-sm font-semibold text-slate-600 hover:text-blue-600 px-4 py-2 rounded-xl hover:bg-slate-100/70 transition-all">Home</a>
                        <a href="/Users/Reservation"
                           class="text-sm font-semibold text-blue-600 bg-blue-50/80 px-4 py-2 rounded-xl transition-all flex items-center space-x-1.5">
                            <svg class="w-4 h-4 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                                 stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                      d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                            </svg>
                            <span>Reservation</span>
                        </a>
                        <a href="/Users/Inquiry"
                           class="text-sm font-semibold text-slate-600 hover:text-blue-600 px-4 py-2 rounded-xl hover:bg-slate-100/70 transition-all flex items-center space-x-1.5">
                            <svg class="w-4 h-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                                 stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                      d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                            <span>Inquiry</span>
                        </a>
                    </nav>
                </div>

                <div class="flex items-center space-x-4">
                    <span
                        class="text-[10px] font-bold uppercase tracking-wider bg-emerald-500 text-white px-2.5 py-1 rounded-lg shadow-sm">Active
                        Member</span>
                        <a href="/index?handler=Logout"
                           class="text-sm font-semibold text-rose-600 hover:text-white px-4 py-2 rounded-xl border border-rose-200 hover:bg-rose-600 transition-all duration-200 shadow-sm">Log
                            Out</a>
                        </div>
                    </div>
                </header>

                <!-- Main Workspace Container -->
                <main class="max-w-7xl w-full mx-auto flex-grow p-6 sm:p-12 space-y-8 z-10">

                    <!-- Live Search and Info Header Panel -->
                    <div class="bg-white/80 border border-white/50 p-6 rounded-3xl shadow-xl backdrop-blur-md animate-fade-in-up flex flex-col md:flex-row items-center justify-between gap-4"
                         style="animation-delay: 0.1s;">
                        <div class="w-full md:max-w-md relative">
                            <span class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
                                <svg class="h-5 w-5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                                     stroke-width="2.5">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                          d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                                </svg>
                            </span>
                            <input type="text" id="catalogSearch" onkeyup="filterCatalog()"
                                   placeholder="Search books by title, publisher, or catalog number..."
                                   class="w-full pl-11 pr-4 py-3 bg-white border border-slate-200 rounded-2xl shadow-inner text-sm placeholder-slate-400 font-medium focus:outline-none focus:ring-2 focus:ring-blue-500/20 transition-all" />
                        </div>
                        <p
                            class="text-xs text-slate-500 font-medium bg-slate-100/80 px-4 py-2 rounded-xl border border-slate-200/50">
                            ⚠️ <span class="text-slate-700 font-bold">Reservation Policy:</span> Maximum of 5 simultaneous items
                            allowed across both active loans and pending holds combined.
                        </p>
                    </div>

                    <!-- Dynamic Catalog Grid Matrix -->
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 animate-fade-in-up" id="catalogGrid"
                         style="animation-delay: 0.2s;">
                        @foreach (var book in Model.CatalogBooks)
                        {
                            var isReference = book.Status.Trim().Equals("Reference", StringComparison.OrdinalIgnoreCase) ||
                        book.CopyCount <= 0;

                            <div class="book-card bg-white/95 border border-white/70 rounded-3xl shadow-lg p-6 flex flex-col justify-between hover:scale-[1.02] hover:shadow-xl transition-all duration-300"
                                 data-title="@book.Title.ToLower()" data-publisher="@book.Publisher.ToLower()"
                                 data-number="@book.BookNumber.ToLower()">

                                <div class="space-y-4">
                                    <div class="flex items-center justify-between">
                                        <span
                                        class="text-[10px] font-mono font-bold text-slate-400 bg-slate-100 px-2.5 py-1 rounded-lg">@book.BookNumber</span>
                                        <span
                                            class="px-2.5 py-1 text-[10px] font-bold uppercase tracking-wider rounded-lg @(isReference ? "bg-rose-50 text-rose-600 border border-rose-100" : "bg-emerald-50 text-emerald-600 border border-emerald-100")">
                                            @(isReference ? "Reference Only" : "Borrowable")
                                        </span>
                                    </div>

                                    <div>
                                        <h3 class="text-lg font-bold text-slate-900 leading-snug truncate-2-lines h-14">@book.Title</h3>
                                        <p class="text-xs text-slate-400 font-medium mt-1">Publisher: <span
                                            class="text-slate-600 font-semibold">@book.Publisher</span></p>
                                        </div>

                                        <div
                                            class="flex items-center justify-between border-t border-slate-100 pt-4 text-xs font-medium text-slate-500">
                                            <span>Available stock:</span>
                                            <span
                                                class="@(book.CopyCount > 0 ? "text-slate-900 font-bold" : "text-rose-500 font-bold")">@book.CopyCount
                                                Copies</span>
                                            </div>
                                        </div>

                                        <div class="mt-6">
                                            @if (isReference)
                                            {
                                                <button disabled
                                                        class="w-full py-3 bg-slate-100 border border-slate-200 text-slate-400 font-bold rounded-2xl text-xs cursor-not-allowed text-center">
                                                    Out of Stock / Reference Hold
                                                </button>
                                            }
                                            else
                                            {
                                                <form method="post">
                                                    <input type="hidden" name="bookNumber" value="@book.BookNumber" />
                                                    <button type="submit"
                                                            class="w-full py-3 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white font-bold rounded-2xl text-xs shadow-md transition-all duration-200 transform active:scale-95">
                                                        Reserve Title
                                                    </button>
                                                </form>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        </main>

                        <!-- Unified Modal Alert Overlay Container -->
                        @if (TempData["ModalType"] != null)
                        {
                            <div id="statusModal"
                                 class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm flex items-center justify-center z-[100] p-4">
                                <div
                                    class="bg-white rounded-3xl p-8 max-w-sm w-full text-center shadow-2xl space-y-5 border border-slate-100 animate-fade-in-up transform scale-100 transition-transform">
                                    @if (TempData["ModalType"].ToString() == "SUCCESS")
                                    {
                                        <div
                                            class="w-16 h-16 bg-emerald-50 text-emerald-500 border border-emerald-200 rounded-full flex items-center justify-center mx-auto shadow-sm">
                                            <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                                            </svg>
                                        </div>
                                        <h3 class="text-xl font-extrabold text-slate-900">Reservation Confirmed!</h3>
                                        <p class="text-xs text-slate-500">Your secure pickup token reference key has been generated safely inside
                                            the ledger network:</p>
                                            <div
                                                class="bg-blue-50 text-blue-700 font-mono text-xl font-black py-3 rounded-2xl tracking-wider select-all border border-blue-100">
                                                @TempData["ModalMessage"]
                                            </div>
                                            <p class="text-[10px] text-slate-400 leading-normal">Present this transaction code identifier value to the
                                                library circulation counter assistant within 48 hours to collect your copy.</p>
                                            }
                else
                                            {
                                                <div
                                                    class="w-16 h-16 bg-rose-50 text-rose-500 border border-rose-200 rounded-full flex items-center justify-center mx-auto shadow-sm">
                                                    <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                                                        <path stroke-linecap="round" stroke-linejoin="round"
                                                              d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                                                    </svg>
                                                </div>
                                                <h3 class="text-xl font-extrabold text-slate-900">Request Declined</h3>
                                                <p class="text-xs text-slate-500 leading-relaxed">@TempData["ModalMessage"]</p>
                                            }
                                            <button onclick="closeModal()"
                                                    class="w-full bg-slate-900 hover:bg-slate-800 text-white font-bold py-3 rounded-2xl text-xs transition shadow-sm">
                                                Dismiss View
                                            </button>
                                        </div>
                                    </div>
                                }

                                <!-- 🌟 EXACT PREMIUM FOOTER LAYOUT (Identical to Home Page, Full-Width, Absolute Bottom Pin) -->
                                <footer
                                    class="w-full bg-white/95 border-t border-slate-200/60 mt-auto shadow-inner backdrop-blur-md z-10 animate-fade-in-up"
                                    style="animation-delay: 0.3s;">
                                    <div class="max-w-7xl mx-auto px-6 py-10 grid grid-cols-1 md:grid-cols-3 gap-8 text-slate-600">

                                        <!-- Left Panel: Brand & Mission -->
                                        <div class="space-y-3">
                                            <div class="flex items-center space-x-2.5">
                                                <div
                                                    class="flex items-center justify-center w-7 h-7 rounded-lg bg-gradient-to-br from-blue-600 to-indigo-600 shadow-sm">
                                                    <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2.5"
                                                         stroke="currentColor">
                                                        <path stroke-linecap="round" stroke-linejoin="round"
                                                              d="M12 21V4.5l7.5-3v16.5L12 21zm0 0L4.5 18V1.5l7.5 3V21z" />
                                                    </svg>
                                                </div>
                                                <span
                                                    class="text-lg font-bold tracking-tight bg-gradient-to-r from-blue-700 to-indigo-600 bg-clip-text text-transparent">Sarasavi
                                                    Library</span>
                                                </div>
                                                <p class="text-xs text-slate-400 font-light leading-relaxed max-w-xs">
                                                    Empowering minds through seamless access to knowledge, digital reservation management, and
                                                    interactive resource collections.
                                                </p>
                                            </div>

                                            <!-- Middle Panel: Operating Hours -->
                                            <div class="space-y-2">
                                                <h4 class="text-xs font-bold uppercase tracking-wider text-slate-400 flex items-center space-x-1.5">
                                                    <svg class="w-3.5 h-3.5 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                                                         stroke-width="2.5">
                                                        <path stroke-linecap="round" stroke-linejoin="round"
                                                              d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                                                    </svg>
                                                    <span>Desk Counter Hours</span>
                                                </h4>
                                                <ul class="text-xs space-y-1 text-slate-500 font-medium">
                                                    <li class="flex justify-between max-w-[220px]"><span>Weekdays:</span> <span
                                                        class="text-slate-700">8:00 AM – 6:00 PM</span></li>
                                                        <li class="flex justify-between max-w-[220px]"><span>Saturdays:</span> <span
                                                            class="text-slate-700">9:00 AM – 4:00 PM</span></li>
                                                            <li class="flex justify-between max-w-[220px]"><span>Sundays / Poya:</span> <span
                                                                class="text-rose-500 font-semibold">Closed</span></li>
                                                            </ul>
                                                        </div>

                                                        <!-- Right Panel: Quick Contacts -->
                                                        <div class="space-y-2">
                                                            <h4 class="text-xs font-bold uppercase tracking-wider text-slate-400 flex items-center space-x-1.5">
                                                                <svg class="w-3.5 h-3.5 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                                                                     stroke-width="2.5">
                                                                    <path stroke-linecap="round" stroke-linejoin="round"
                                                                          d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                                                                </svg>
                                                                <span>Front Desk Contact</span>
                                                            </h4>
                                                            <div class="text-xs space-y-1 text-slate-500 font-medium">
                                                                <p>Hotline: <span class="text-slate-700 font-mono">+94 11 234 5678</span></p>
                                                                <p>Support: <a href="mailto:support@sarasavi.lk"
                                                                                   class="text-blue-600 hover:underline">support@sarasavi.lk</a></p>
                                                                </div>
                                                            </div>

                                                        </div>

                                                        <!-- Lower Trademark Bar -->
                                                        <div
                                                            class="w-full border-t border-slate-200/50 py-4 text-center text-[11px] text-slate-400 font-medium bg-slate-50/50">
                                                            &copy; @DateTime.Now.Year Sarasavi Library Circulation Network. All rights reserved. Built with precision.
                                                        </div>
                                                    </footer>

                                                    <!-- Embedded Vanilla JavaScript Search Processing & Interaction Matrix -->
                                                    <script>
                                                        function filterCatalog() {
                                                        const input = document.getElementById('catalogSearch').value.toLowerCase();
                                                        const cards = document.getElementsByClassName('book-card');

                                                        for (let i = 0; i < cards.length; i++) {
                                                        const title = cards[i].getAttribute('data-title');
                                                        const publisher = cards[i].getAttribute('data-publisher');
                                                        const number = cards[i].getAttribute('data-number');

                                                        if (title.includes(input) || publisher.includes(input) || number.includes(input)) {
                                                        cards[i].style.display = "flex";
                                                        } else {
                                                        cards[i].style.display = "none";
                                                        }
                                                        }
                                                        }

                                                        function closeModal() {
                                                        const modal = document.getElementById('statusModal');
                                                        if (modal) {
                                                        modal.style.opacity = '0';
                                                        setTimeout(() => modal.remove(), 150);
                                                        }
                                                        }
                                                    </script>
                                                </body>

                                            </html>