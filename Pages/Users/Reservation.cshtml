@page
@model SarasaviLibrary.Pages.Users.ReservationModel
@{
    ViewData["Title"] = "Reserve Books";
    Layout = null;
}

<script src="https://cdn.tailwindcss.com"></script>

<div class="min-h-screen bg-slate-50 text-slate-800 font-sans antialiased flex flex-col justify-between">
    <header class="w-full bg-white border-b border-slate-200 sticky top-0 z-40 shadow-sm">
        <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
            <div class="flex items-center space-x-8">
                <a href="/index" class="flex items-center space-x-3">
                    <div
                        class="flex items-center justify-center w-10 h-10 rounded-xl bg-gradient-to-br from-blue-600 to-indigo-600 shadow-md">
                        <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2.5"
                             stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M12 21V4.5l7.5-3v16.5L12 21zm0 0L4.5 18V1.5l7.5 3V21z" />
                        </svg>
                    </div>
                    <span
                        class="text-2xl font-bold tracking-tight bg-gradient-to-r from-blue-700 to-indigo-600 bg-clip-text text-transparent">Sarasavi
                        Library</span>
                    </a>
                    <nav class="hidden md:flex items-center space-x-2 border-l border-slate-200 pl-8">
                        <a href="/Users/Home"
                           class="text-sm font-semibold text-slate-600 hover:text-blue-600 px-4 py-2 rounded-xl transition-all">Dashboard</a>
                        <a href="/Users/Reservation"
                           class="text-sm font-semibold text-blue-600 bg-blue-50 px-4 py-2 rounded-xl transition-all">Reservation</a>
                        <a href="/Users/Inquiry"
                           class="text-sm font-semibold text-slate-600 hover:text-blue-600 px-4 py-2 rounded-xl transition-all">Inquiry</a>
                    </nav>
                </div>
                <div class="flex items-center space-x-4">
                    <span
                    class="text-xs font-bold text-slate-400 bg-slate-100 px-3 py-1.5 rounded-lg font-mono">@Model.CurrentUserNumber</span>
                    <a href="/index?handler=Logout"
                       class="text-sm font-medium text-rose-600 hover:text-rose-700 px-3 py-2 rounded-lg transition-colors">Log
                        Out</a>
                    </div>
                </div>
            </header>

            <main class="max-w-7xl w-full mx-auto flex-grow p-6 sm:p-12 space-y-8">
                <div>
                    <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight">Book Reservation Desk</h1>
                    <p class="text-sm text-slate-500 font-light">Request up to 5 borrowable books from our catalog inventory
                        system.</p>
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
                        @foreach (var book in Model.CatalogBooks)
                        {
                            <div
                                class="bg-white border border-slate-200 p-5 rounded-2xl shadow-sm hover:shadow-md transition-all flex flex-col justify-between space-y-4">
                                <div class="space-y-2">
                                    <span
                                        class="px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider rounded-md @(book.Status == "Reference" ? "bg-amber-50 text-amber-700 border border-amber-200" : "bg-emerald-50 text-emerald-700 border border-emerald-200")">
                                        @book.Status
                                    </span>
                                    <h4 class="text-base font-bold text-slate-900 tracking-tight line-clamp-2 pt-1">@book.Title</h4>
                                    <p class="text-xs text-slate-400 font-medium">Publisher: <span
                                        class="text-slate-600">@book.Publisher</span></p>
                                    </div>

                                    <div class="pt-3 border-t border-slate-100 flex items-center justify-between">
                                        <div class="text-xs font-medium text-slate-500">
                                            Available: <span class="font-bold text-slate-800">@book.CopyCount</span>
                                        </div>

                                        <form method="post">
                                            <input type="hidden" name="bookNumber" value="@book.BookNumber" />
                                            <button type="submit"
                                                    class="bg-blue-600 hover:bg-blue-700 text-white font-semibold text-xs px-4 py-2 rounded-xl transition shadow-sm">
                                                Add Book
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            }
                        </div>
                    </main>

                    @if (TempData["ModalType"] != null)
                    {
                        <div class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-slate-900/60 backdrop-blur-sm shadow-2xl">
                            <div class="bg-white max-w-sm w-full p-8 rounded-3xl shadow-2xl border border-slate-100 text-center space-y-5">

                                @if (TempData["ModalType"].ToString() == "SUCCESS")
                                {
                                    <div
                                        class="mx-auto flex items-center justify-center h-12 w-12 rounded-full bg-emerald-100 text-emerald-600">
                                        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                                        </svg>
                                    </div>
                                    <h3 class="text-lg font-bold text-slate-900">Book Reserved Successfully!</h3>
                                    <p class="text-xs text-slate-500 font-light">Show this temporary allocation code at the librarian collection
                                        desk:</p>
                                        <div
                                            class="bg-slate-50 border border-slate-200 p-3 rounded-xl font-mono font-bold text-lg text-blue-700 tracking-wider">
                                            @TempData["ModalMessage"]
                                        </div>
                                    }
                else
                                    {
                                        <div class="mx-auto flex items-center justify-center h-12 w-12 rounded-full bg-rose-100 text-rose-600">
                                            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round"
                                                      d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
                                            </svg>
                                        </div>
                                        <h3 class="text-lg font-bold text-slate-900">Action Denied</h3>
                                        <p class="text-sm text-slate-600 font-medium px-2">@TempData["ModalMessage"]</p>
                                    }

                                    <a href="/Users/Reservation"
                                       class="block w-full bg-slate-900 hover:bg-slate-800 text-white font-semibold py-2.5 rounded-xl text-xs transition">
                                        Dismiss
                                    </a>
                                </div>
                            </div>
                        }

                        <footer class="w-full bg-white border-t border-slate-200 py-4 text-center text-xs text-slate-400 font-medium">
                            &copy; @DateTime.Now.Year Sarasavi Library System. All rights reserved.
                        </footer>
                    </div>