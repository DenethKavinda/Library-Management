@page
@model SarasaviLibrary.Pages.Users.HomeModel
@{
    ViewData["Title"] = "Member Home - Sarasavi Library";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @@keyframes fadeInDown {
        from {
        opacity: 0;
        transform: translateY(-16px);
        }

        to {
        opacity: 1;
        transform: translateY(0);
        }
        }

        @@keyframes fadeInUp {
        from {
        opacity: 0;
        transform: translateY(24px);
        }

        to {
        opacity: 1;
        transform: translateY(0);
        }
        }

        .animate-fade-in-down {
        animation: fadeInDown 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }

        .animate-fade-in-up {
        animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) both;
        }
    </style>
</head>

<body
    class="min-h-screen font-sans antialiased flex flex-col justify-between relative bg-cover bg-center bg-no-repeat bg-fixed"
    style="background-image: url('/images/home.jpg');">

    <div class="absolute inset-0 bg-slate-900/40 backdrop-blur-[6px] z-0"></div>

    <header
        class="w-full bg-white/90 border-b border-white/20 sticky top-0 z-50 shadow-md backdrop-blur-md animate-fade-in-down">
        <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
            <div class="flex items-center space-x-8">
                <a href="/index" class="flex items-center space-x-3 group">
                    <div
                        class="flex items-center justify-center w-10 h-10 rounded-xl bg-gradient-to-br from-blue-600 to-indigo-600 shadow-md transform group-hover:scale-105 transition-transform duration-200">
                        <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2.5"
                             stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M12 21V4.5l7.5-3v16.5L12 21zm0 0L4.5 18V1.5l7.5 3V21z" />
                        </svg>
                    </div>
                    <span
                        class="text-2xl font-bold tracking-tight bg-gradient-to-r from-blue-700 to-indigo-600 bg-clip-text text-transparent group-hover:from-blue-600 group-hover:to-indigo-500 transition-colors">Sarasavi
                        Library</span>
                    </a>

                    <nav class="hidden md:flex items-center space-x-1 border-l border-slate-200 pl-8">
                        <a href="/Users/Home"
                           class="text-sm font-semibold text-blue-600 bg-blue-50/80 px-4 py-2 rounded-xl transition-all">Home</a>
                        <a href="/Users/Reservation"
                           class="text-sm font-semibold text-slate-600 hover:text-blue-600 px-4 py-2 rounded-xl hover:bg-slate-100/70 transition-all flex items-center space-x-1.5">
                            <svg class="w-4 h-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                                 stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                      d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                            </svg>
                            <span>Reservation</span>
                        </a>
                        <a href="/Users/Inquiry"
                           class="text-sm font-semibold text-slate-600 hover:text-blue-600 px-4 py-2 rounded-xl hover:bg-slate-100/70 transition-all flex items-center space-x-1.5">
                            <svg class="w-4 h-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                                 stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                      d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                            <span>Inquiry</span>
                        </a>
                    </nav>
                </div>

                <div class="flex items-center space-x-4">
                    <span
                        class="text-[10px] font-bold uppercase tracking-wider bg-emerald-500 text-white px-2.5 py-1 rounded-lg shadow-sm">Active
                        Member</span>
                        <a href="/index?handler=Logout"
                           class="text-sm font-semibold text-rose-600 hover:text-white px-4 py-2 rounded-xl border border-rose-200 hover:bg-rose-600 transition-all duration-200 shadow-sm">Log
                            Out</a>
                        </div>
                    </div>
                </header>

                <main class="max-w-7xl w-full mx-auto flex-grow p-6 sm:p-12 space-y-8 z-10">

                    <div class="bg-white/80 border border-white/50 p-8 rounded-3xl shadow-xl backdrop-blur-md animate-fade-in-up flex flex-col md:flex-row items-start md:items-center justify-between gap-6"
                         style="animation-delay: 0.1s;">
                        <div class="space-y-2">
                            <h1 class="text-4xl font-extrabold text-slate-900 tracking-tight">
                                Hello, <span
                                class="bg-gradient-to-r from-blue-600 to-indigo-600 bg-clip-text text-transparent">@Model.CurrentUserName</span>
                                👋
                            </h1>
                            <p class="text-slate-600 font-medium">Welcome back to your Sarasavi Library card desk dashboard portal.
                            </p>
                            <div class="pt-2 flex items-center space-x-4 text-xs font-mono font-bold text-slate-400">
                                <span>CARD ID: <span
                                    class="text-slate-700 bg-slate-200/60 px-2 py-0.5 rounded">@Model.CurrentUserNumber</span></span>
                                    <span>NIC: <span
                                        class="text-slate-700 bg-slate-200/60 px-2 py-0.5 rounded">@Model.CurrentUserNIC</span></span>
                                    </div>
                                </div>

                                <div class="bg-white/90 border border-slate-100 p-5 rounded-2xl shadow-sm text-center min-w-[200px]">
                                    <span class="block text-[10px] font-bold uppercase tracking-widest text-slate-400 mb-1">Quota
                                        Usage</span>
                                        <div class="text-3xl font-black text-slate-900">
                                            <span class="text-blue-600">@Model.TotalOccupiedSlots</span> <span
                                            class="text-slate-300 font-light">/</span> 5
                                        </div>
                                        <div class="w-full bg-slate-100 h-2 rounded-full mt-2.5 overflow-hidden">
                                            <div class="bg-gradient-to-r from-blue-500 to-indigo-600 h-full rounded-full transition-all duration-500"
                                                 style="width: @(Model.TotalOccupiedSlots * 20)%"></div>
                                        </div>
                                        <span class="block text-[10px] text-slate-400 font-medium mt-2">
                                            @(5 - Model.TotalOccupiedSlots) slots remaining available
                                        </span>
                                    </div>
                                </div>

                                <div class="grid grid-cols-1 md:grid-cols-3 gap-6 animate-fade-in-up" style="animation-delay: 0.2s;">

                                    <div
                                        class="bg-white/95 border border-white/60 p-6 rounded-2xl shadow-lg flex flex-col justify-between hover:scale-[1.01] transition-transform duration-200">
                                        <div class="space-y-4">
                                            <div class="flex items-center justify-between">
                                                <h3 class="text-sm font-bold uppercase tracking-wider text-slate-400">My Checked-out Books</h3>
                                                <span
                                                    class="bg-blue-50 text-blue-700 text-xs font-bold px-2.5 py-1 rounded-full">@Model.ActiveLoans.Count
                                                    Active</span>
                                                </div>
                                                @if (!Model.ActiveLoans.Any())
                                                {
                                                    <p class="text-sm text-slate-400 font-light py-4">You have no physical books currently home on loan.
                                                    </p>
                                                }
                                                else
                                                {
                                                    <div class="space-y-2 max-h-48 overflow-y-auto pr-1">
                                                        @foreach (var loan in Model.ActiveLoans)
                                                        {
                                                            <div
                                                                class="p-3 bg-slate-50 border border-slate-100 rounded-xl flex justify-between items-center">
                                                                <div class="truncate pr-2">
                                                                    <p class="text-xs font-bold text-slate-800 truncate">@loan.BookNumber</p>
                                                                    <p class="text-[10px] text-slate-400">Due: @loan.DueDate.ToString("yyyy-MM-dd")</p>
                                                                </div>
                                                                <span class="text-[10px] font-bold text-emerald-600 whitespace-nowrap">
                                                                    @((loan.DueDate - DateTime.Now).Days)d left
                                                                </span>
                                                            </div>
                                                        }
                                                    </div>
                                                }
                                            </div>
                                            <a href="/Users/Reservation"
                                               class="mt-4 w-full text-center bg-slate-900 hover:bg-slate-800 text-white font-semibold py-2.5 rounded-xl text-xs transition shadow-sm">
                                                Browse Books to Borrow
                                            </a>
                                        </div>

                                        <div
                                            class="bg-white/95 border border-white/60 p-6 rounded-2xl shadow-lg flex flex-col justify-between hover:scale-[1.01] transition-transform duration-200">
                                            <div class="space-y-4">
                                                <div class="flex items-center justify-between">
                                                    <h3 class="text-sm font-bold uppercase tracking-wider text-slate-400">Pending Holds Queue</h3>
                                                    <span
                                                        class="bg-amber-50 text-amber-700 text-xs font-bold px-2.5 py-1 rounded-full">@Model.PendingReservations.Count
                                                        Holds</span>
                                                    </div>
                                                    @if (!Model.PendingReservations.Any())
                                                    {
                                                        <p class="text-sm text-slate-400 font-light py-4">No reservations waiting collection counter
                                                            clearance.</p>
                                                        }
                    else
                                                        {
                                                            <div class="space-y-2 max-h-48 overflow-y-auto pr-1">
                                                                @foreach (var res in Model.PendingReservations)
                                                                {
                                                                    <div
                                                                        class="p-3 bg-amber-50/40 border border-amber-100 rounded-xl flex justify-between items-center">
                                                                        <div>
                                                                            <p class="text-xs font-bold text-slate-800 font-mono text-blue-700">@res.ReservationCode
                                                                            </p>
                                                                            <p class="text-[10px] text-slate-400">Book Reference: @res.BookNumber</p>
                                                                        </div>
                                                                        <span
                                                                            class="text-[9px] uppercase tracking-wider font-extrabold text-amber-600 bg-amber-100/60 px-2 py-0.5 rounded">
                                                                            Pending
                                                                        </span>
                                                                    </div>
                                                                }
                                                            </div>
                                                        }
                                                    </div>
                                                    <div
                                                        class="bg-slate-50 border border-slate-100 rounded-xl p-3 text-[11px] text-slate-500 font-medium leading-relaxed mt-4">
                                                        💡 <strong>Collection Rule:</strong> Present your generated code tokens to the librarian desk window
                                                        to authorize loan checkout processing.
                                                    </div>
                                                </div>

                                                <div
                                                    class="bg-white/95 border border-white/60 p-6 rounded-2xl shadow-lg flex flex-col justify-between hover:scale-[1.01] transition-transform duration-200">
                                                    <div class="space-y-4">
                                                        <h3 class="text-sm font-bold uppercase tracking-wider text-slate-400">Library Desk Support</h3>
                                                        <div
                                                            class="p-4 bg-gradient-to-br from-blue-50 to-indigo-50/50 border border-blue-100 rounded-2xl space-y-2">
                                                            <h4 class="text-xs font-bold text-slate-800">Need Account Assistance?</h4>
                                                            <p class="text-xs text-slate-500 font-light leading-relaxed">Have a question regarding overdue
                                                                fees, catalog missing items, or extending borrow periods? Drop an electronic notice ticket
                                                                instantly.</p>
                                                            </div>
                                                        </div>
                                                        <a href="/Users/Inquiry"
                                                           class="w-full text-center bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2.5 rounded-xl text-xs transition shadow-md">
                                                            Submit Support Inquiry
                                                        </a>
                                                    </div>

                                                </div>
                                            </main>

                                            <!-- Unified Premium Footer Layout -->
                                            <footer
                                                class="w-full bg-white/95 border-t border-slate-200/60 mt-auto shadow-inner backdrop-blur-md z-10 animate-fade-in-up"
                                                style="animation-delay: 0.3s;">
                                                <div class="max-w-7xl mx-auto px-6 py-10 grid grid-cols-1 md:grid-cols-3 gap-8 text-slate-600">

                                                    <!-- Left Panel: Brand & Mission -->
                                                    <div class="space-y-3">
                                                        <div class="flex items-center space-x-2.5">
                                                            <div
                                                                class="flex items-center justify-center w-7 h-7 rounded-lg bg-gradient-to-br from-blue-600 to-indigo-600 shadow-sm">
                                                                <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2.5"
                                                                     stroke="currentColor">
                                                                    <path stroke-linecap="round" stroke-linejoin="round"
                                                                          d="M12 21V4.5l7.5-3v16.5L12 21zm0 0L4.5 18V1.5l7.5 3V21z" />
                                                                </svg>
                                                            </div>
                                                            <span
                                                                class="text-lg font-bold tracking-tight bg-gradient-to-r from-blue-700 to-indigo-600 bg-clip-text text-transparent">Sarasavi
                                                                Library</span>
                                                            </div>
                                                            <p class="text-xs text-slate-400 font-light leading-relaxed max-w-xs">
                                                                Empowering minds through seamless access to knowledge, digital reservation management, and
                                                                interactive resource collections.
                                                            </p>
                                                        </div>

                                                        <!-- Middle Panel: Operating Hours -->
                                                        <div class="space-y-2">
                                                            <h4 class="text-xs font-bold uppercase tracking-wider text-slate-400 flex items-center space-x-1.5">
                                                                <svg class="w-3.5 h-3.5 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                                                                     stroke-width="2.5">
                                                                    <path stroke-linecap="round" stroke-linejoin="round"
                                                                          d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                                                                </svg>
                                                                <span>Desk Counter Hours</span>
                                                            </h4>
                                                            <ul class="text-xs space-y-1 text-slate-500 font-medium">
                                                                <li class="flex justify-between max-w-[220px]"><span>Weekdays:</span> <span
                                                                    class="text-slate-700">8:00 AM – 6:00 PM</span></li>
                                                                    <li class="flex justify-between max-w-[220px]"><span>Saturdays:</span> <span
                                                                        class="text-slate-700">9:00 AM – 4:00 PM</span></li>
                                                                        <li class="flex justify-between max-w-[220px]"><span>Sundays / Poya:</span> <span
                                                                            class="text-rose-500 font-semibold">Closed</span></li>
                                                                        </ul>
                                                                    </div>

                                                                    <!-- Right Panel: Quick Contacts -->
                                                                    <div class="space-y-2">
                                                                        <h4 class="text-xs font-bold uppercase tracking-wider text-slate-400 flex items-center space-x-1.5">
                                                                            <svg class="w-3.5 h-3.5 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                                                                                 stroke-width="2.5">
                                                                                <path stroke-linecap="round" stroke-linejoin="round"
                                                                                      d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                                                                            </svg>
                                                                            <span>Front Desk Contact</span>
                                                                        </h4>
                                                                        <div class="text-xs space-y-1 text-slate-500 font-medium">
                                                                            <p>Hotline: <span class="text-slate-700 font-mono">+94 11 234 5678</span></p>
                                                                            <p>Support: <a href="mailto:support@sarasavi.lk"
                                                                                               class="text-blue-600 hover:underline">support@sarasavi.lk</a></p>
                                                                            </div>
                                                                        </div>

                                                                    </div>

                                                                    <!-- Lower Trademark Bar -->
                                                                    <div
                                                                        class="w-full border-t border-slate-200/50 py-4 text-center text-[11px] text-slate-400 font-medium bg-slate-50/50">
                                                                        &copy; @DateTime.Now.Year Sarasavi Library Circulation Network. All rights reserved. Built with precision.
                                                                    </div>
                                                                </footer>
                                                            </body>

                                                        </html>