@page
@model SarasaviLibrary.Pages.Users.HomeModel
@{
    ViewData["Title"] = "Member Home - Sarasavi Library";
    Layout = null;
}

<script src="https://cdn.tailwindcss.com"></script>

<div class="min-h-screen bg-slate-50 text-slate-800 font-sans antialiased flex flex-col justify-between">
    <!-- Member Header -->
    <header class="w-full bg-white border-b border-slate-200 sticky top-0 z-50 shadow-sm">
        <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
            <!-- Left: Logo Grouping -->
            <div class="flex items-center space-x-8">
                <a href="/index" class="flex items-center space-x-3">
                    <div
                        class="flex items-center justify-center w-10 h-10 rounded-xl bg-gradient-to-br from-blue-600 to-indigo-600 shadow-md">
                        <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2.5"
                             stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M12 21V4.5l7.5-3v16.5L12 21zm0 0L4.5 18V1.5l7.5 3V21z" />
                        </svg>
                    </div>
                    <span
                        class="text-2xl font-bold tracking-tight bg-gradient-to-r from-blue-700 to-indigo-600 bg-clip-text text-transparent">Sarasavi
                        Library</span>
                    </a>

                    <!-- 💡 Center/Left: New Portal Navigation Action Buttons -->
                    <nav class="hidden md:flex items-center space-x-2 border-l border-slate-200 pl-8">
                        <a href="/Users/Reservation"
                           class="text-sm font-semibold text-slate-600 hover:text-blue-600 px-4 py-2 rounded-xl hover:bg-slate-50 transition-all flex items-center space-x-1.5">
                            <svg class="w-4 h-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                                 stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                      d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                            </svg>
                            <span>Reservation</span>
                        </a>
                        <a href="/Users/Inquiry"
                           class="text-sm font-semibold text-slate-600 hover:text-blue-600 px-4 py-2 rounded-xl hover:bg-slate-50 transition-all flex items-center space-x-1.5">
                            <svg class="w-4 h-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                                 stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                      d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                            <span>Inquiry</span>
                        </a>
                    </nav>
                </div>

                <!-- Right: Profile Status & Logout -->
                <div class="flex items-center space-x-4">
                    <span
                        class="text-xs font-semibold uppercase tracking-wider bg-emerald-50 text-emerald-700 px-2.5 py-1 rounded-lg hidden sm:inline-block">Active
                        Member</span>
                        <a href="/index?handler=Logout"
                           class="text-sm font-medium text-rose-600 hover:text-rose-700 px-3 py-2 rounded-lg hover:bg-rose-50 transition-colors">Log
                            Out</a>
                        </div>
                    </div>
                </header>

                <!-- Main Workspace Area -->
                <main class="max-w-7xl w-full mx-auto flex-grow p-6 sm:p-12 space-y-8">
                    <div class="bg-white border border-slate-200 p-8 rounded-3xl shadow-sm space-y-4">
                        <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight">Welcome to Your Portal</h1>
                        <p class="text-slate-500 font-light">Manage your digital library card, checked-out loans, and account status
                            credentials seamlessly.</p>
                        </div>

                        <!-- Dashboard Widgets -->
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
                                <h3 class="text-sm font-bold uppercase tracking-wider text-slate-400 mb-2">My Active Borrows</h3>
                                <p class="text-sm text-slate-500 font-light">You currently have no books checked out under your account.
                                </p>
                            </div>
                            <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
                                <h3 class="text-sm font-bold uppercase tracking-wider text-slate-400 mb-2">Account Safety Notice</h3>
                                <p class="text-sm text-slate-500 font-light">Always present your custom User Number to the librarian
                                    desk when checking out physical items.</p>
                                </div>
                            </div>
                        </main>

                        <!-- Footer -->
                        <footer class="w-full bg-white border-t border-slate-200 py-4 text-center text-xs text-slate-400 font-medium">
                            &copy; @DateTime.Now.Year Sarasavi Library System. All rights reserved.
                        </footer>
                    </div>