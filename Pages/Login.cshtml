@page
@model SarasaviLibrary.Pages.LoginModel
@{
    ViewData["Title"] = "Log In - Sarasavi Library";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @@keyframes fadeInDown {
        from {
        opacity: 0;
        transform: translateY(-16px);
        }

        to {
        opacity: 1;
        transform: translateY(0);
        }
        }

        @@keyframes fadeInUp {
        from {
        opacity: 0;
        transform: translateY(24px);
        }

        to {
        opacity: 1;
        transform: translateY(0);
        }
        }

        .animate-fade-in-down {
        animation: fadeInDown 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }

        .animate-fade-in-up {
        animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) both;
        }
    </style>
</head>

<body
    class="min-h-screen font-sans antialiased flex flex-col justify-between relative bg-cover bg-center bg-no-repeat bg-fixed m-0 p-0"
    style="background-image: url('/images/library-bg.jpg');">

    <div class="absolute inset-0 bg-slate-900/40 backdrop-blur-[6px] z-0"></div>

    <header
        class="w-full bg-white/90 border-b border-white/20 sticky top-0 z-50 shadow-md backdrop-blur-md animate-fade-in-down">
        <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
            <div class="flex items-center space-x-3 group">
                <div
                    class="flex items-center justify-center w-10 h-10 rounded-xl bg-gradient-to-br from-blue-600 to-indigo-600 shadow-md transform group-hover:scale-105 transition-transform duration-200">
                    <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2.5"
                         stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M12 21V4.5l7.5-3v16.5L12 21zm0 0L4.5 18V1.5l7.5 3V21z" />
                    </svg>
                </div>
                <span
                    class="text-2xl font-bold tracking-tight bg-gradient-to-r from-blue-700 to-indigo-600 bg-clip-text text-transparent group-hover:from-blue-600 group-hover:to-indigo-500 transition-colors">Sarasavi
                    Library</span>
                </div>

                <div class="flex items-center space-x-4">
                    <a href="/"
                       class="text-sm font-semibold text-slate-700 hover:text-blue-700 border border-slate-300 hover:border-blue-500 transition-all duration-200 px-4 py-2 rounded-xl bg-white/50 backdrop-blur shadow-sm flex items-center space-x-1.5">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 1110.5 3a7.5 7.5 0 015.803 12.803z" />
                        </svg>
                        <span>Search Books</span>
                    </a>
                </div>
            </div>
        </header>

        <main class="w-full flex-grow flex items-center justify-center p-6 z-10">
            <div class="max-w-md w-full bg-white/85 border border-white/60 p-8 sm:p-10 rounded-3xl shadow-2xl backdrop-blur-md animate-fade-in-up flex flex-col justify-between"
                 style="animation-delay: 0.1s;">

                <div class="text-center space-y-2 mb-8">
                    <h2 class="text-3xl font-black text-slate-900 tracking-tight">Welcome Back</h2>
                    <p class="text-sm text-slate-500 font-medium">Enter your card details to access your member profile.</p>
                </div>

                <form method="post" class="space-y-5">

                    @if (!ModelState.IsValid && HttpContext.Request.Method == "POST")
                    {
                        <div
                            class="p-4 bg-rose-50 border border-rose-100 rounded-2xl flex items-start space-x-3 text-xs text-rose-600 animate-fade-in-up">
                            <svg class="w-4 h-4 text-rose-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24"
                                 stroke="currentColor" stroke-width="2.5">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                      d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                            </svg>
                            <div class="font-medium leading-normal" asp-validation-summary="All"></div>
                        </div>
                    }

                    <div class="space-y-1.5">
                        <label class="text-xs font-bold uppercase tracking-wider text-slate-500">User Number</label>
                        <div class="relative">
                            <span class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
                                <svg class="h-4 w-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                                     stroke-width="2.5">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                          d="M16 7a4 4 0 11-8 0 4 4 0 0118 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                                </svg>
                            </span>
                            <input type="text" asp-for="LoginInput.UserNumber" placeholder="e.g., REG - 00000001" required
                                   autocomplete="username"
                                   class="w-full pl-10 pr-4 py-3 bg-white border border-slate-200 rounded-2xl text-sm text-slate-700 placeholder-slate-400 font-medium uppercase focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all shadow-inner" />
                        </div>
                    </div>

                    <div class="space-y-1.5">
                        <label class="text-xs font-bold uppercase tracking-wider text-slate-500">NIC Number</label>
                        <div class="relative">
                            <span class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
                                <svg class="h-4 w-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                                     stroke-width="2.5">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                          d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                                </svg>
                            </span>
                            <input type="text" asp-for="LoginInput.NIC" placeholder="e.g., 991234567V" required
                                   autocomplete="current-password"
                                   class="w-full pl-10 pr-4 py-3 bg-white border border-slate-200 rounded-2xl text-sm text-slate-700 placeholder-slate-400 font-medium uppercase focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all shadow-inner" />
                        </div>
                    </div>

                    <button type="submit"
                            class="w-full py-3.5 mt-2 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white font-bold rounded-2xl text-xs shadow-md transition-all duration-200 transform active:scale-[0.98]">
                        Log In
                    </button>
                </form>

                <div class="mt-6 pt-5 border-t border-slate-200/50 text-center">
                    <p class="text-xs text-slate-400 font-medium">
                        Don't have an account yet?
                        <a href="/Signup" class="text-blue-600 hover:underline font-bold transition-colors">Sign up here</a>
                    </p>
                </div>

            </div>
        </main>

        <footer
            class="w-full bg-white/95 border-t border-slate-200/60 mt-auto shadow-inner backdrop-blur-md z-10 animate-fade-in-up"
            style="animation-delay: 0.2s;">
            <div class="max-w-7xl mx-auto px-6 py-10 grid grid-cols-1 md:grid-cols-3 gap-8 text-slate-600">

                <div class="space-y-3">
                    <div class="flex items-center space-x-2.5">
                        <div
                            class="flex items-center justify-center w-7 h-7 rounded-lg bg-gradient-to-br from-blue-600 to-indigo-600 shadow-sm">
                            <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2.5"
                                 stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                      d="M12 21V4.5l7.5-3v16.5L12 21zm0 0L4.5 18V1.5l7.5 3V21z" />
                            </svg>
                        </div>
                        <span
                            class="text-lg font-bold tracking-tight bg-gradient-to-r from-blue-700 to-indigo-600 bg-clip-text text-transparent">Sarasavi
                            Library</span>
                        </div>
                        <p class="text-xs text-slate-400 font-light leading-relaxed max-w-xs">
                            Empowering minds through seamless access to knowledge, digital reservation management, and
                            interactive resource collections.
                        </p>
                    </div>

                    <div class="space-y-2">
                        <h4 class="text-xs font-bold uppercase tracking-wider text-slate-400 flex items-center space-x-1.5">
                            <svg class="w-3.5 h-3.5 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                                 stroke-width="2.5">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                      d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                            <span>Desk Counter Hours</span>
                        </h4>
                        <ul class="text-xs space-y-1 text-slate-500 font-medium">
                            <li class="flex justify-between max-w-[220px]"><span>Weekdays:</span> <span
                                class="text-slate-700">8:00 AM – 6:00 PM</span></li>
                                <li class="flex justify-between max-w-[220px]"><span>Saturdays:</span> <span
                                    class="text-slate-700">9:00 AM – 4:00 PM</span></li>
                                    <li class="flex justify-between max-w-[220px]"><span>Sundays / Poya:</span> <span
                                        class="text-rose-500 font-semibold">Closed</span></li>
                                    </ul>
                                </div>

                                <div class="space-y-2">
                                    <h4 class="text-xs font-bold uppercase tracking-wider text-slate-400 flex items-center space-x-1.5">
                                        <svg class="w-3.5 h-3.5 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                                             stroke-width="2.5">
                                            <path stroke-linecap="round" stroke-linejoin="round"
                                                  d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                                        </svg>
                                        <span>Front Desk Contact</span>
                                    </h4>
                                    <div class="text-xs space-y-1 text-slate-500 font-medium">
                                        <p>Hotline: <span class="text-slate-700 font-mono">+94 11 234 5678</span></p>
                                        <p>Support: <a href="mailto:support@sarasavi.lk"
                                                           class="text-blue-600 hover:underline">support@sarasavi.lk</a></p>
                                        </div>
                                    </div>

                                </div>

                                <div
                                    class="w-full border-t border-slate-200/50 py-4 text-center text-[11px] text-slate-400 font-medium bg-slate-50/50">
                                    &copy; @DateTime.Now.Year Sarasavi Library Circulation Network. All rights reserved. Built with precision.
                                </div>
                            </footer>
                        </body>

                    </html>