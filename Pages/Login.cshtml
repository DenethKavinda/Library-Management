@page
@model SarasaviLibrary.Pages.LoginModel
@{
    ViewData["Title"] = "Log In - Sarasavi Library";
    Layout = null;
}

<script src="https://cdn.tailwindcss.com"></script>

<div class="min-h-screen font-sans antialiased flex flex-col justify-between relative bg-cover bg-center bg-no-repeat bg-fixed"
     style="background-image: url('/images/library-bg.jpg');">

    <div class="absolute inset-0 bg-white/80 backdrop-blur-[2px] z-0"></div>

    <header class="w-full bg-white/90 border-b border-slate-200/80 sticky top-0 z-50 shadow-sm backdrop-blur-md">
        <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
            <a href="/" class="flex items-center space-x-3">
                <div
                    class="flex items-center justify-center w-10 h-10 rounded-xl bg-gradient-to-br from-blue-600 to-indigo-600 shadow-md">
                    <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2.5"
                         stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M12 21V4.5l7.5-3v16.5L12 21zm0 0L4.5 18V1.5l7.5 3V21z" />
                    </svg>
                </div>
                <span
                    class="text-2xl font-bold tracking-tight bg-gradient-to-r from-blue-700 to-indigo-600 bg-clip-text text-transparent">Sarasavi
                    Library</span>
                </a>

                <div class="flex items-center space-x-4">
                    <a href="/"
                       class="text-sm font-semibold text-slate-700 hover:text-blue-700 border border-slate-300 hover:border-blue-500 transition-all duration-200 px-4 py-2 rounded-xl bg-white/50 backdrop-blur shadow-sm flex items-center space-x-1.5">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 1110.5 3a7.5 7.5 0 015.803 12.803z" />
                        </svg>
                        <span>Search Books</span>
                    </a>
                </div>
            </div>
        </header>

        <main class="flex-grow flex items-center justify-center px-4 py-12 z-10">
            <div class="max-w-md w-full bg-white/50 border border-white/70 p-8 rounded-3xl backdrop-blur-md shadow-xl">
                <div class="text-center space-y-2 mb-8">
                    <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight">Welcome Back</h1>
                    <p class="text-sm text-slate-500 font-light">Enter your card details to access your member profile.</p>
                </div>

                @if (!ModelState.IsValid && HttpContext.Request.Method == "POST")
                {
                    <div class="p-4 mb-6 bg-rose-50 border border-rose-200 text-rose-800 rounded-xl text-xs font-medium">
                        <div asp-validation-summary="All"></div>
                    </div>
                }

                <form method="post" class="space-y-5">
                    <div>
                        <label class="block text-xs font-semibold uppercase tracking-wider text-slate-500 mb-1.5">User
                            Number</label>
                            <input type="text" asp-for="LoginInput.UserNumber" placeholder="e.g., REG - 00000001"
                                   class="w-full px-4 py-3 bg-white/80 border border-slate-200 rounded-xl text-slate-700 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 font-medium uppercase"
                                   required />
                        </div>

                        <div>
                            <label class="block text-xs font-semibold uppercase tracking-wider text-slate-500 mb-1.5">NIC
                                Number</label>
                                <input type="text" asp-for="LoginInput.NIC" placeholder="e.g., 991234567V"
                                       class="w-full px-4 py-3 bg-white/80 border border-slate-200 rounded-xl text-slate-700 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 font-medium uppercase"
                                       required />
                            </div>

                            <button type="submit"
                                    class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3.5 rounded-xl shadow-md transition-all duration-200 mt-2">
                                Sign In
                            </button>
                        </form>

                        <div class="text-center mt-6">
                            <p class="text-xs text-slate-500">Don't have an account yet? <a href="/Signup"
                                                                                                class="text-blue-600 font-semibold hover:underline">Sign up here</a></p>
                            </div>
                        </div>
                    </main>

                    <footer
                        class="w-full bg-white/95 border-t border-slate-200 py-4 text-center text-xs text-slate-500 z-10 backdrop-blur-sm">
                        &copy; @DateTime.Now.Year Sarasavi Library System. All rights reserved.
                    </footer>
                </div>