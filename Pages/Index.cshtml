@page
@model IndexModel
@{
    ViewData["Title"] = "Welcome to Sarasavi Library";
    Layout = null;
}

<script src="https://cdn.tailwindcss.com"></script>

<div class="min-h-screen font-sans antialiased flex flex-col justify-between relative bg-cover bg-center bg-no-repeat bg-fixed"
     style="background-image: url('/images/library-bg.jpg');">

    <div class="absolute inset-0 bg-white/80 backdrop-blur-[2px] z-0"></div>

    <header class="w-full bg-white/90 border-b border-slate-200/80 sticky top-0 z-50 shadow-sm backdrop-blur-md">
        <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
            <div class="flex items-center space-x-3">
                <div
                    class="flex items-center justify-center w-10 h-10 rounded-xl bg-gradient-to-br from-blue-600 to-indigo-600 shadow-md shadow-blue-500/20">
                    <svg class="w-5 h-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                         stroke-width="2.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M12 21V4.5l7.5-3v16.5L12 21zm0 0L4.5 18V1.5l7.5 3V21z" />
                    </svg>
                </div>
                <span
                    class="text-2xl font-bold tracking-tight bg-gradient-to-r from-blue-700 to-indigo-600 bg-clip-text text-transparent">
                    Sarasavi Library
                </span>
            </div>

            <div class="flex items-center space-x-4">
                <a href="/Login"
                   class="text-sm font-medium text-slate-600 hover:text-blue-700 transition-colors duration-200 px-4 py-2 rounded-lg hover:bg-slate-100">
                    Log In
                </a>
                <a href="/Signup"
                   class="text-sm font-semibold text-white bg-blue-600 hover:bg-blue-700 shadow-md hover:shadow-lg transition-all duration-200 px-5 py-2.5 rounded-lg">
                    Sign Up
                </a>
            </div>
        </div>
    </header>

    <main
        class="flex-grow flex flex-col items-center justify-start px-4 sm:px-6 lg:px-8 pt-12 pb-24 z-10 space-y-12 max-w-7xl w-full mx-auto">

        <div
            class="max-w-2xl w-full text-center space-y-6 bg-white/40 border border-white/60 p-8 rounded-3xl backdrop-blur-md shadow-xl shadow-slate-200/40">
            <div class="space-y-2">
                <h1 class="text-4xl font-extrabold text-slate-900 tracking-tight">Discover Your Next Read</h1>
                <p class="text-sm text-slate-600 font-light">Access thousands of books instantly from our library
                    network catalog.</p>
                </div>

                <form method="get"
                      class="bg-white p-2 rounded-2xl shadow-lg border border-slate-200/80 flex items-center transition-all duration-300 focus-within:ring-2 focus-within:ring-blue-500/20 focus-within:border-blue-500">
                    <div class="flex-grow flex items-center">
                        <div class="flex-grow relative flex items-center px-3">
                            <svg class="h-5 w-5 text-slate-400 absolute left-4" xmlns="http://www.w3.org/2000/svg"
                                 fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                      d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 1 5.196 5.196a7.5 7.5 0 0 1 10.608 10.608Z" />
                            </svg>
                            <input type="text" name="searchQuery" value="@Model.SearchQuery"
                                   placeholder="Search by book name or author..."
                                   class="w-full pl-8 pr-4 py-3 text-slate-700 placeholder-slate-400 bg-transparent border-none focus:outline-none text-base font-medium" />
                        </div>
                    </div>
                    <button type="submit"
                            class="bg-blue-600 hover:bg-blue-700 text-white font-medium px-6 py-3 rounded-xl shadow transition-all">
                        Search
                    </button>
                </form>
            </div>

            <div class="w-full space-y-8">
                <div id="bookGrid" class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
                    @if (!Model.BooksList.Any())
                    {
                        <div
                            class="col-span-full text-center bg-white/60 backdrop-blur-sm p-12 rounded-2xl border border-slate-200/50">
                            <p class="text-slate-500 font-medium">No matches found in the catalog. Try another title or
                                category.</p>
                            </div>
                        }
                else
                        {
                            @foreach (var book in Model.BooksList)
                            {
                                <div
                                    class="book-card hidden bg-white/95 border border-slate-200/60 p-5 rounded-2xl shadow-sm hover:shadow-md transition-all duration-200 flex flex-col justify-between space-y-4">
                                    <div class="space-y-2">
                                        <div class="w-8 h-8 rounded-lg bg-blue-50 text-blue-600 flex items-center justify-center mb-3">
                                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                                                 stroke-width="2.5">
                                                <path stroke-linecap="round" stroke-linejoin="round"
                                                      d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253" />
                                            </svg>
                                        </div>
                                        <h4 class="text-base font-bold text-slate-900 tracking-tight line-clamp-2" title="@book.Title">
                                            @book.Title
                                        </h4>
                                        <p class="text-xs font-medium text-slate-400">
                                            Publisher: <span class="text-slate-600">@book.Publisher</span>
                                        </p>
                                    </div>

                                    <div class="pt-3 border-t border-slate-100 flex items-center justify-between">
                                        <span class="text-xs font-semibold text-slate-500">Available Copies</span>
                                        <span
                                            class="px-2.5 py-1 text-xs font-bold rounded-lg @(book.CopyCount > 0 ? "bg-emerald-50 text-emerald-700" : "bg-amber-50 text-amber-700")">
                                            @book.CopyCount
                                        </span>
                                    </div>
                                </div>
                            }
                        }
                    </div>

                    @if (Model.BooksList.Any())
                    {
                        <div class="flex justify-center pt-4">
                            <button id="btnLoadMore"
                                    class="bg-white hover:bg-slate-50 text-slate-700 font-semibold px-6 py-3 border border-slate-300 rounded-xl shadow-sm transition-all flex items-center space-x-2">
                                <span>Show More Books</span>
                                <svg class="w-4 h-4 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                                     stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                                </svg>
                            </button>
                        </div>
                    }
                </div>
            </main>

            <footer
                class="w-full bg-white/95 border-t border-slate-200 py-6 text-center text-xs text-slate-500 font-medium z-10 backdrop-blur-sm">
                &copy; @DateTime.Now.Year Sarasavi Library System. All rights reserved.
            </footer>
        </div>

        <script>
            document.addEventListener("DOMContentLoaded", function () {
            const cardsPerPage = 8; // 4 columns * 2 rows = 8 cards per block iteration
            const cards = Array.from(document.querySelectorAll(".book-card"));
            const btnMore = document.getElementById("btnLoadMore");
            let currentVisibleCount = 0;

            function revealNextBatch() {
            let revealedThisTurn = 0;

            for (let i = currentVisibleCount; i < cards.length; i++) {
            if (revealedThisTurn < cardsPerPage) {
            cards[i].classList.remove("hidden");
            revealedThisTurn++;
            } else {
            break;
            }
            }

            currentVisibleCount += revealedThisTurn;

            // Automatically hide button block if no remaining elements wait to render
            if (currentVisibleCount >= cards.length && btnMore) {
            btnMore.classList.add("hidden");
            }
            }

            // Initialize display configuration on first startup
            if (cards.length > 0) {
            revealNextBatch();
            if (btnMore) {
            btnMore.addEventListener("click", revealNextBatch);
            }
            }
            });
        </script>