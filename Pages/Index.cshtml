@page
@model IndexModel
@{
    ViewData["Title"] = "Welcome to Sarasavi Library";
    Layout = null;
}

<!-- Tailwind CSS CDN for modern UI styling -->
<script src="https://cdn.tailwindcss.com"></script>

<div class="min-h-screen font-sans antialiased flex flex-col justify-between relative bg-cover bg-center bg-no-repeat"
     style="background-image: url('/images/library-bg.jpg');">

    <!-- Smooth background tint layer to keep the UI light and clear -->
    <div class="absolute inset-0 bg-white/80 backdrop-blur-[2px] z-0"></div>

    <!-- Top Navigation Bar -->
    <header class="w-full bg-white/90 border-b border-slate-200/80 sticky top-0 z-50 shadow-sm backdrop-blur-md">
        <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
            <!-- Library Logo & Name -->
            <div class="flex items-center space-x-3">
                <!-- Modern Academic Logo Icon -->
                <div
                    class="flex items-center justify-center w-10 h-10 rounded-xl bg-gradient-to-br from-blue-600 to-indigo-600 shadow-md shadow-blue-500/20">
                    <svg class="w-5 h-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                         stroke-width="2.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M12 21V4.5l7.5-3v16.5L12 21zm0 0L4.5 18V1.5l7.5 3V21z" />
                    </svg>
                </div>
                <!-- Library Title -->
                <span
                    class="text-2xl font-bold tracking-tight bg-gradient-to-r from-blue-700 to-indigo-600 bg-clip-text text-transparent">
                    Sarasavi Library
                </span>
            </div>

            <!-- Auth Action Buttons -->
            <div class="flex items-center space-x-4">
                <a href="/Login"
                   class="text-sm font-medium text-slate-600 hover:text-blue-700 transition-colors duration-200 px-4 py-2 rounded-lg hover:bg-slate-100">
                    Log In
                </a>
                <a href="/Signup"
                   class="text-sm font-semibold text-white bg-blue-600 hover:bg-blue-700 shadow-md hover:shadow-lg transition-all duration-200 px-5 py-2.5 rounded-lg">
                    Sign Up
                </a>
            </div>
        </div>
    </header>

    <!-- Main Content Area -->
    <main class="flex-grow flex items-center justify-center px-4 sm:px-6 lg:px-8 -mt-20 z-10">
        <!-- Frosted glass card panel for high contrast text readability -->
        <div
            class="max-w-2xl w-full text-center space-y-8 bg-white/40 border border-white/60 p-8 sm:p-12 rounded-3xl backdrop-blur-md shadow-xl shadow-slate-200/40">

            <!-- Hero Header -->
            <div class="space-y-3">
                <h1 class="text-4xl sm:text-5xl font-extrabold text-slate-900 tracking-tight">
                    Discover Your Next Read
                </h1>
                <p class="text-base sm:text-lg text-slate-600 max-w-md mx-auto font-light">
                    Access thousands of books, journals, and digital archives instantly.
                </p>
            </div>

            <!-- Unified Search Bar Form -->
            <form method="get"
                  class="bg-white p-2 rounded-2xl shadow-lg shadow-slate-300/30 border border-slate-200/80 flex items-center transition-all duration-300 focus-within:ring-2 focus-within:ring-blue-500/20 focus-within:border-blue-500">
                <div class="flex-grow flex items-center divide-x divide-slate-200">
                    <!-- Search Input -->
                    <div class="flex-grow relative flex items-center px-3">
                        <svg class="h-5 w-5 text-slate-400 absolute left-4" xmlns="http://www.w3.org/2000/svg"
                             fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 1 5.196 5.196a7.5 7.5 0 0 1 10.608 10.608Z" />
                        </svg>
                        <input type="text" name="searchQuery" placeholder="Search by book title or author..."
                               class="w-full pl-8 pr-4 py-3 text-slate-700 placeholder-slate-400 bg-transparent border-none focus:outline-none text-base font-medium" />
                    </div>
                </div>

                <!-- Search Button -->
                <button type="submit"
                        class="bg-blue-600 hover:bg-blue-700 text-white font-medium px-6 py-3 rounded-xl shadow transition-all duration-200 flex items-center space-x-2">
                    <span>Search</span>
                </button>
            </form>

            <!-- Quick Suggestion Tags -->
            <div class="flex flex-wrap items-center justify-center gap-2 text-xs font-semibold text-slate-500">
                <span>Popular searches:</span>
                <a href="?searchQuery=Fiction"
                   class="bg-white/80 border border-slate-200/60 text-slate-700 px-3 py-1 rounded-full hover:border-blue-500 hover:text-blue-600 hover:bg-white transition-colors">Fiction</a>
                <a href="?searchQuery=Science"
                   class="bg-white/80 border border-slate-200/60 text-slate-700 px-3 py-1 rounded-full hover:border-blue-500 hover:text-blue-600 hover:bg-white transition-colors">Science</a>
                <a href="?searchQuery=History"
                   class="bg-white/80 border border-slate-200/60 text-slate-700 px-3 py-1 rounded-full hover:border-blue-500 hover:text-blue-600 hover:bg-white transition-colors">History</a>
            </div>

        </div>
    </main>

    <!-- Simple, Clean Footer -->
    <footer
        class="w-full bg-white/95 border-t border-slate-200 py-6 text-center text-xs text-slate-500 font-medium z-10 backdrop-blur-sm">
        &copy; @DateTime.Now.Year Sarasavi Library System. All rights reserved.
    </footer>
</div>