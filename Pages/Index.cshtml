@page
@model IndexModel
@{
    ViewData["Title"] = "Welcome to Sarasavi Library";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @@keyframes fadeInDown {
        from {
        opacity: 0;
        transform: translateY(-16px);
        }

        to {
        opacity: 1;
        transform: translateY(0);
        }
        }

        @@keyframes fadeInUp {
        from {
        opacity: 0;
        transform: translateY(24px);
        }

        to {
        opacity: 1;
        transform: translateY(0);
        }
        }

        .animate-fade-in-down {
        animation: fadeInDown 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }

        .animate-fade-in-up {
        animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) both;
        }
    </style>
</head>

<body
    class="min-h-screen font-sans antialiased flex flex-col justify-between relative bg-cover bg-center bg-no-repeat bg-fixed m-0 p-0"
    style="background-image: url('/images/library-bg.jpg');">

    <div class="absolute inset-0 bg-slate-900/40 backdrop-blur-[6px] z-0"></div>

    <header
        class="w-full bg-white/90 border-b border-white/20 sticky top-0 z-50 shadow-md backdrop-blur-md animate-fade-in-down">
        <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
            <div class="flex items-center space-x-3 group">
                <div
                    class="flex items-center justify-center w-10 h-10 rounded-xl bg-gradient-to-br from-blue-600 to-indigo-600 shadow-md transform group-hover:scale-105 transition-transform duration-200">
                    <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2.5"
                         stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M12 21V4.5l7.5-3v16.5L12 21zm0 0L4.5 18V1.5l7.5 3V21z" />
                    </svg>
                </div>
                <span
                    class="text-2xl font-bold tracking-tight bg-gradient-to-r from-blue-700 to-indigo-600 bg-clip-text text-transparent group-hover:from-blue-600 group-hover:to-indigo-500 transition-colors">Sarasavi
                    Library</span>
                </div>

                <div class="flex items-center space-x-4">
                    <a href="/Login"
                       class="text-sm font-semibold text-slate-600 hover:text-blue-600 px-4 py-2 rounded-xl hover:bg-slate-100/70 transition-all duration-200">
                        Log In
                    </a>
                    <a href="/Signup"
                       class="text-sm font-semibold text-white bg-blue-600 hover:bg-blue-700 px-5 py-2.5 rounded-xl shadow-md hover:shadow-lg transition-all duration-200">
                        Sign Up
                    </a>
                </div>
            </div>
        </header>

        <main
            class="max-w-7xl w-full mx-auto flex-grow p-6 sm:p-12 space-y-12 z-10 flex flex-col items-center justify-start">

            <div class="max-w-2xl w-full text-center space-y-6 bg-white/80 border border-white/50 p-8 rounded-3xl shadow-xl backdrop-blur-md animate-fade-in-up"
                 style="animation-delay: 0.1s;">
                <div class="space-y-2">
                    <h1 class="text-4xl font-extrabold text-slate-900 tracking-tight">Discover Your Next Read</h1>
                    <p class="text-sm text-slate-600 font-medium">Access thousands of books instantly from our library
                        network catalog.</p>
                    </div>

                    <form method="get"
                          class="bg-white p-2 rounded-2xl shadow-md border border-slate-200/80 flex items-center transition-all duration-300 focus-within:ring-2 focus-within:ring-blue-500/20 focus-within:border-blue-500">
                        <div class="flex-grow relative flex items-center px-3">
                            <svg class="h-5 w-5 text-slate-400 absolute left-4" fill="none" viewBox="0 0 24 24" stroke-width="2"
                                 stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                      d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 1 5.196 5.196a7.5 7.5 0 0 1 10.608 10.608Z" />
                            </svg>
                            <input type="text" name="searchQuery" value="@Model.SearchQuery"
                                   placeholder="Search by book name or author..."
                                   class="w-full pl-8 pr-4 py-3 text-slate-700 placeholder-slate-400 bg-transparent border-none focus:outline-none text-base font-medium" />
                        </div>
                        <button type="submit"
                                class="bg-blue-600 hover:bg-blue-700 text-white font-semibold px-6 py-3 rounded-xl shadow transition-all duration-200">
                            Search
                        </button>
                    </form>
                </div>

                <div class="w-full space-y-8 animate-fade-in-up" style="animation-delay: 0.2s;">
                    <div id="bookGrid" class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
                        @if (!Model.BooksList.Any())
                        {
                            <div
                                class="col-span-full text-center bg-white/80 backdrop-blur-md p-12 rounded-3xl border border-white/50 shadow-xl">
                                <p class="text-slate-500 font-semibold">No matches found in the catalog. Try another title or
                                    category.</p>
                                </div>
                            }
                else
                            {
                                @foreach (var book in Model.BooksList)
                                {
                                    <div
                                        class="book-card hidden bg-white/95 border border-white/70 p-6 rounded-3xl shadow-lg hover:scale-[1.02] hover:shadow-xl transition-all duration-300 flex flex-col justify-between space-y-4">
                                        <div class="space-y-3">
                                            <div class="w-8 h-8 rounded-lg bg-blue-50 text-blue-600 flex items-center justify-center mb-1">
                                                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                                                     stroke-width="2.5">
                                                    <path stroke-linecap="round" stroke-linejoin="round"
                                                          d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253" />
                                                </svg>
                                            </div>
                                            <h4 class="text-base font-bold text-slate-900 tracking-tight line-clamp-2 h-12"
                                                title="@book.Title">
                                                @book.Title
                                            </h4>
                                            <p class="text-xs font-medium text-slate-400">
                                                Publisher: <span class="text-slate-600 font-semibold">@book.Publisher</span>
                                            </p>
                                        </div>

                                        <div class="pt-4 border-t border-slate-100 flex items-center justify-between">
                                            <span class="text-xs font-bold text-slate-400 uppercase tracking-wider">Available Copies</span>
                                            <span
                                                class="px-2.5 py-1 text-xs font-extrabold rounded-lg @(book.CopyCount > 0 ? "bg-emerald-50 text-emerald-700 border border-emerald-100" : "bg-amber-50 text-amber-700 border border-amber-100")">
                                                @book.CopyCount
                                            </span>
                                        </div>
                                    </div>
                                }
                            }
                        </div>

                        @if (Model.BooksList.Any())
                        {
                            <div class="flex justify-center pt-4">
                                <button id="btnLoadMore"
                                        class="bg-white hover:bg-slate-50 text-slate-700 font-bold px-6 py-3 border border-slate-200 rounded-xl shadow-md transition-all flex items-center space-x-2 transform active:scale-95">
                                    <span>Show More Books</span>
                                    <svg class="w-4 h-4 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                                         stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                                    </svg>
                                </button>
                            </div>
                        }
                    </div>
                </main>

                <footer
                    class="w-full bg-white/95 border-t border-slate-200/60 mt-auto shadow-inner backdrop-blur-md z-10 animate-fade-in-up"
                    style="animation-delay: 0.3s;">
                    <div class="max-w-7xl mx-auto px-6 py-10 grid grid-cols-1 md:grid-cols-3 gap-8 text-slate-600">

                        <div class="space-y-3">
                            <div class="flex items-center space-x-2.5">
                                <div
                                    class="flex items-center justify-center w-7 h-7 rounded-lg bg-gradient-to-br from-blue-600 to-indigo-600 shadow-sm">
                                    <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2.5"
                                         stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round"
                                              d="M12 21V4.5l7.5-3v16.5L12 21zm0 0L4.5 18V1.5l7.5 3V21z" />
                                    </svg>
                                </div>
                                <span
                                    class="text-lg font-bold tracking-tight bg-gradient-to-r from-blue-700 to-indigo-600 bg-clip-text text-transparent">Sarasavi
                                    Library</span>
                                </div>
                                <p class="text-xs text-slate-400 font-light leading-relaxed max-w-xs">
                                    Empowering minds through seamless access to knowledge, digital reservation management, and
                                    interactive resource collections.
                                </p>
                            </div>

                            <div class="space-y-2">
                                <h4 class="text-xs font-bold uppercase tracking-wider text-slate-400 flex items-center space-x-1.5">
                                    <svg class="w-3.5 h-3.5 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                                         stroke-width="2.5">
                                        <path stroke-linecap="round" stroke-linejoin="round"
                                              d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                                    </svg>
                                    <span>Desk Counter Hours</span>
                                </h4>
                                <ul class="text-xs space-y-1 text-slate-500 font-medium">
                                    <li class="flex justify-between max-w-[220px]"><span>Weekdays:</span> <span
                                        class="text-slate-700">8:00 AM – 6:00 PM</span></li>
                                        <li class="flex justify-between max-w-[220px]"><span>Saturdays:</span> <span
                                            class="text-slate-700">9:00 AM – 4:00 PM</span></li>
                                            <li class="flex justify-between max-w-[220px]"><span>Sundays / Poya:</span> <span
                                                class="text-rose-500 font-semibold">Closed</span></li>
                                            </ul>
                                        </div>

                                        <div class="space-y-2">
                                            <h4 class="text-xs font-bold uppercase tracking-wider text-slate-400 flex items-center space-x-1.5">
                                                <svg class="w-3.5 h-3.5 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                                                     stroke-width="2.5">
                                                    <path stroke-linecap="round" stroke-linejoin="round"
                                                          d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                                                </svg>
                                                <span>Front Desk Contact</span>
                                            </h4>
                                            <div class="text-xs space-y-1 text-slate-500 font-medium">
                                                <p>Hotline: <span class="text-slate-700 font-mono">+94 11 234 5678</span></p>
                                                <p>Support: <a href="mailto:support@sarasavi.lk"
                                                                   class="text-blue-600 hover:underline">support@sarasavi.lk</a></p>
                                                </div>
                                            </div>

                                        </div>

                                        <div
                                            class="w-full border-t border-slate-200/50 py-4 text-center text-[11px] text-slate-400 font-medium bg-slate-50/50">
                                            &copy; @DateTime.Now.Year Sarasavi Library Circulation Network. All rights reserved. Built with precision.
                                        </div>
                                    </footer>

                                    <script>
                                        document.addEventListener("DOMContentLoaded", function () {
                                        const cardsPerPage = 8;
                                        const cards = Array.from(document.querySelectorAll(".book-card"));
                                        const btnMore = document.getElementById("btnLoadMore");
                                        let currentVisibleCount = 0;

                                        function revealNextBatch() {
                                        let revealedThisTurn = 0;

                                        for (let i = currentVisibleCount; i < cards.length; i++) {
                                        if (revealedThisTurn < cardsPerPage) {
                                        cards[i].classList.remove("hidden");
                                        revealedThisTurn++;
                                        } else {
                                        break;
                                        }
                                        }

                                        currentVisibleCount += revealedThisTurn;

                                        if (currentVisibleCount >= cards.length && btnMore) {
                                        btnMore.classList.add("hidden");
                                        }
                                        }

                                        if (cards.length > 0) {
                                        revealNextBatch();
                                        if (btnMore) {
                                        btnMore.addEventListener("click", revealNextBatch);
                                        }
                                        }
                                        });
                                    </script>
                                </body>

                            </html>