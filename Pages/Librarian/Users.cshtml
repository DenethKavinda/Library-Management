@page
@model SarasaviLibrary.Pages.Librarian.UsersModel
@{
    ViewData["Title"] = "Registered Users";
    Layout = "_LibrarianLayout";
}

<div class="max-w-6xl mx-auto space-y-6">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h2 class="text-2xl font-bold text-slate-900 tracking-tight">Library Members</h2>
            <p class="text-sm text-slate-500 font-light">View and manage all registered borrowers inside
                SarasaviLibraryDB.</p>
            </div>
            <div
                class="bg-white border border-slate-200 px-4 py-2 rounded-xl shadow-sm flex items-center space-x-2 self-start sm:self-auto">
                <span class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Total Members:</span>
                <span class="text-sm font-bold text-blue-600">@Model.RegisteredUsers.Count</span>
            </div>
        </div>

        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr
                            class="bg-slate-50 border-b border-slate-200 text-xs font-semibold uppercase tracking-wider text-slate-400">
                            <th class="p-4 pl-6">User Number</th>
                            <th class="p-4">Full Name</th>
                            <th class="p-4">Sex</th>
                            <th class="p-4">NIC Number</th>
                            <th class="p-4 pr-6">Address</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100 text-sm text-slate-700 font-medium">
                        @if (!Model.RegisteredUsers.Any())
                        {
                            <tr>
                                <td colspan="5" class="p-12 text-center text-slate-400 font-light">
                                    <div class="flex flex-col items-center justify-center space-y-2">
                                        <svg class="w-8 h-8 text-slate-300" fill="none" viewBox="0 0 24 24"
                                             stroke="currentColor" stroke-width="1.5">
                                            <path stroke-linecap="round" stroke-linejoin="round"
                                                  d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
                                        </svg>
                                        <span>No active library card holders found.</span>
                                    </div>
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var user in Model.RegisteredUsers)
                            {
                                <tr class="hover:bg-slate-50/60 transition-colors">
                                    <td class="p-4 pl-6 font-mono text-xs font-bold text-blue-700">
                                        @user.UserNumber
                                    </td>
                                    <td class="p-4 text-slate-900 font-semibold">
                                        @user.FullName
                                    </td>
                                    <td class="p-4">
                                        <span
                                            class="px-2 py-0.5 text-xs font-medium rounded-full @(user.Sex == "Male" ? "bg-blue-50 text-blue-700" : "bg-purple-50 text-purple-700")">
                                            @user.Sex
                                        </span>
                                    </td>
                                    <td class="p-4 font-mono text-xs text-slate-600">
                                        @user.NIC
                                    </td>
                                    <td class="p-4 pr-6 text-slate-500 max-w-xs truncate" title="@user.Address">
                                        @user.Address
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>