@page
@model SarasaviLibrary.Pages.Librarian.IndexModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "_LibrarianLayout"; // 👈 Tells Razor to use our new sidebar layout
}

<div class="space-y-6">
    <div>
        <h2 class="text-2xl font-bold text-slate-900 tracking-tight">Welcome Back, Librarian</h2>
        <p class="text-sm text-slate-500 font-light">Here is what's happening with SarasaviLibraryDB today.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm space-y-2">
            <span class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Total Active Users</span>
            <div class="text-3xl font-bold text-slate-900">1,240</div>
        </div>
        <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm space-y-2">
            <span class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Books Registered</span>
            <div class="text-3xl font-bold text-slate-900">8,450</div>
        </div>
        <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm space-y-2">
            <span class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Active Loans</span>
            <div class="text-3xl font-bold text-slate-900">320</div>
        </div>
        <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm space-y-2">
            <span class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Overdue Returns</span>
            <div class="text-3xl font-bold text-rose-600">14</div>
        </div>
    </div>
</div>