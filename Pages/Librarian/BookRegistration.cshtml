@page
@model SarasaviLibrary.Pages.Librarian.BookRegistrationModel
@{
    ViewData["Title"] = "Book Registration & Inventory";
    Layout = "_LibrarianLayout";
}

<div class="max-w-6xl mx-auto space-y-8">
    <div>
        <h2 class="text-2xl font-bold text-slate-900 tracking-tight">Book Registration & Inventory</h2>
        <p class="text-sm text-slate-500 font-light">Register new arrivals and manage live inventory counts.</p>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div
            class="p-4 bg-emerald-50 border border-emerald-200 text-emerald-800 rounded-xl text-sm font-medium shadow-sm flex items-center space-x-2">
            <svg class="w-5 h-5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span>@TempData["SuccessMessage"]</span>
        </div>
    }

    <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6">
        <h3 class="text-sm font-bold uppercase tracking-wider text-slate-400 mb-4">Register New Book</h3>
        <form method="post" asp-page-handler="Register" class="space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label
                        class="block text-xs font-semibold uppercase tracking-wider text-slate-500 mb-2">Classification
                        Code</label>
                        <input type="text" asp-for="BookInput.Classification" maxlength="1" placeholder="e.g., F, S, T"
                               class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-slate-700 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 font-medium uppercase"
                               required />
                    </div>
                    <div>
                        <label class="block text-xs font-semibold uppercase tracking-wider text-slate-500 mb-2">Book
                            Title</label>
                            <input type="text" asp-for="BookInput.Title" placeholder="e.g., The Great Gatsby"
                                   class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-slate-700 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 font-medium"
                                   required />
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label
                            class="block text-xs font-semibold uppercase tracking-wider text-slate-500 mb-2">Publisher</label>
                            <input type="text" asp-for="BookInput.Publisher" placeholder="e.g., Penguin Books"
                                   class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-slate-700 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 font-medium"
                                   required />
                        </div>
                        <div>
                            <label class="block text-xs font-semibold uppercase tracking-wider text-slate-500 mb-2">Copy Count
                                (0 - 10)</label>
                                <input type="number" id="copyCountInput" asp-for="BookInput.CopyCount" min="0" max="10" value="0"
                                       class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-slate-700 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 font-semibold"
                                       required />
                            </div>
                        </div>

                        <div>
                            <label class="block text-xs font-semibold uppercase tracking-wider text-slate-500 mb-2">Availability
                                Status</label>
                                <div id="statusBadge"
                                     class="inline-flex items-center px-3 py-1.5 rounded-lg text-xs font-bold uppercase tracking-wider bg-amber-50 text-amber-700 border border-amber-200">
                                    <span id="statusText">Reference Only</span>
                                </div>
                            </div>

                            <div class="pt-2 border-t border-slate-100 flex justify-end">
                                <button type="submit"
                                        class="bg-blue-600 hover:bg-blue-700 text-white font-semibold px-6 py-3 rounded-xl shadow transition-all duration-200">
                                    Register Book
                                </button>
                            </div>
                        </form>
                    </div>

                    <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
                        <div class="p-6 border-b border-slate-100">
                            <h3 class="text-sm font-bold uppercase tracking-wider text-slate-400">Current Catalog Inventory</h3>
                        </div>

                        <div class="overflow-x-auto">
                            <table class="w-full text-left border-collapse">
                                <thead>
                                    <tr
                                        class="bg-slate-50 border-b border-slate-200 text-xs font-semibold uppercase tracking-wider text-slate-400">
                                        <th class="p-4 pl-6">Book Number</th>
                                        <th class="p-4">Class</th>
                                        <th class="p-4">Title</th>
                                        <th class="p-4">Publisher</th>
                                        <th class="p-4">Status</th>
                                        <th class="p-4 pr-6">Copy Count</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-slate-100 text-sm text-slate-700 font-medium">
                                    @if (!Model.RegisteredBooks.Any())
                                    {
                                        <tr>
                                            <td colspan="6" class="p-8 text-center text-slate-400 font-light">No records found inside
                                                SarasaviLibraryDB catalog yet.</td>
                                            </tr>
                                        }
                    else
                                        {
                                            @foreach (var book in Model.RegisteredBooks)
                                            {
                                                <tr class="hover:bg-slate-50/80 transition-colors">
                                                    <td class="p-4 pl-6 font-mono text-xs font-bold text-blue-700">@book.BookNumber</td>
                                                    <td class="p-4 font-mono">@book.Classification</td>
                                                    <td class="p-4 text-slate-900">@book.Title</td>
                                                    <td class="p-4 text-slate-500">@book.Publisher</td>
                                                    <td class="p-4">
                                                        @if (book.Status == "Reference")
                                                        {
                                                            <span
                                                            class="px-2 py-1 text-[10px] font-bold uppercase tracking-wider bg-amber-50 text-amber-700 border border-amber-200 rounded-md">Reference</span>
                                                        }
                                                        else
                                                        {
                                                            <span
                                                            class="px-2 py-1 text-[10px] font-bold uppercase tracking-wider bg-emerald-50 text-emerald-700 border border-emerald-200 rounded-md">Borrowable</span>
                                                        }
                                                    </td>
                                                    <td class="p-4 pr-6">
                                                        <form method="post" asp-page-handler="UpdateCopies" class="flex items-center space-x-2">
                                                            <input type="hidden" name="bookNumber" value="@book.BookNumber" />
                                                            <input type="number" name="newCopyCount" value="@book.CopyCount" min="0" max="10"
                                                                   class="w-16 px-2 py-1 bg-slate-50 border border-slate-200 rounded-lg text-center font-bold focus:outline-none focus:border-blue-500" />
                                                            <button type="submit"
                                                                    class="text-xs bg-slate-100 text-slate-600 px-2 py-1 rounded-lg hover:bg-blue-600 hover:text-white transition-all font-semibold">
                                                                Save
                                                            </button>
                                                        </form>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                    <script>
                        const copyInput = document.getElementById('copyCountInput');
                        const statusText = document.getElementById('statusText');
                        const statusBadge = document.getElementById('statusBadge');

                        function updateStatusUI() {
                            const val = parseInt(copyInput.value) || 0;
                            // 💡 Business rules modification: 0 = Reference, 1-10 = Borrowable
                            if (val === 0) {
                                statusText.textContent = "Reference Only";
                                statusBadge.className = "inline-flex items-center px-3 py-1.5 rounded-lg text-xs font-bold uppercase tracking-wider bg-amber-50 text-amber-700 border border-amber-200";
                            } else {
                                statusText.textContent = "Borrowable";
                                statusBadge.className = "inline-flex items-center px-3 py-1.5 rounded-lg text-xs font-bold uppercase tracking-wider bg-emerald-50 text-emerald-700 border border-emerald-200";
                            }
                        }
                        copyInput.addEventListener('input', updateStatusUI);
                        window.addEventListener('DOMContentLoaded', updateStatusUI);
                    </script>